VISION_BACKEND=huggingface
HF_MODEL=HuggingFaceTB/SmolVLM2-500M-Video-Instruct
HF_DEVICE=cpu
HF_MAX_NEW_TOKENS=256
HF_CPU_THREADS=4
# Set true only after the model has been downloaded once.
HF_LOCAL_FILES_ONLY=false
MAX_IMAGE_SIDE=1024

# Optional local Ollama backend.
OLLAMA_MODEL=qwen2.5vl:7b
OLLAMA_URL=http://localhost:11434

# Optional paid/cloud backend. Install `openai` separately and set
# VISION_BACKEND=openai to use it.
OPENAI_API_KEY=replace_me
OPENAI_VISION_MODEL=gpt-5.5
OPENAI_IMAGE_DETAIL=high
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT_SECONDS=90
LOG_LEVEL=INFO
INPUT_USD_PER_MILLION=2.50
OUTPUT_USD_PER_MILLION=15.00
